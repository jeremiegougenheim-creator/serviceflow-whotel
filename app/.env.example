# ── Supabase ────────────────────────────────────────────────────────────────────
# Current project: lauds-wtaipei  (ap-northeast-1 Tokyo)
# Migration target: serviceflow-wtaipei (ap-southeast-1 Singapore)
# To migrate: create new Supabase project in Singapore, copy schema + RLS,
# seed data, then swap the values below and redeploy.
# PR: chore/supabase-singapore-migration
NEXT_PUBLIC_SUPABASE_URL=[SINGAPORE_PROJECT_URL]
NEXT_PUBLIC_SUPABASE_ANON_KEY=[SINGAPORE_ANON_KEY]
SUPABASE_SERVICE_ROLE_KEY=[SINGAPORE_SERVICE_ROLE_KEY]

# ── AI / Forecast ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
FORECAST_ENGINE_URL=http://localhost:8000

# ── App ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
